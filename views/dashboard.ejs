<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Controle de Gastos</title>
    <link rel="stylesheet" href="/css/inapp.css">
    <link rel="stylesheet" href="/css/modal.css">
</head>

<body>

<div class="sidebar">
    <div class="user">Olá, <%= (typeof userName !== 'undefined') ? userName : '...' %></div>
    <h2>💰 Finanças</h2>

    <button name="createFolder" class="addFolder" onclick="openModal('folders')">Criar pasta</button>
    <button name="excludeFolder" onclick="openModal('exFolders')">Excluir pasta</button>
        <button name="configFolder">Configurar pasta</button>
    <button name="insertbuy">Inserir compra</button>
    <button name="newInvoice">Cadastrar parcela</button>
    <button name="installment">Parcelados</button>
    <button name="insertCard" onclick="openModal('cards')">Cadastrar cartões</button>
</div>

<div class="main">

<div class="header">
    <h1>Seus Gastos</h1>

    <select class="toggle">
        <option value="1">Janeiro</option>
        <option value="2">Fevereiro</option>
        <option value="3">Março</option>
        <option value="4" selected>Abril</option>
    </select>
</div>

<div class="top-controls">
    <select class="toggle">
        <option value="all">Tudo</option>
        <% if (typeof pastas !== 'undefined' && pastas.length > 0) { %>
            <% pastas.forEach(pasta => { %>
                <option value="<%= pasta.id %>"><%= pasta.name %></option>
            <% }) %>
        <% } %>
    </select>

    <input type="text" class="search-input" placeholder="Pesquisar...">
</div>

<div class="table-container">
    <table>
        <thead>
            <tr>
                <th>Produto</th><th>Valor</th><th>Data</th><th>Cartão</th><th>Pasta</th>
            </tr>
        </thead>
        <tbody>
            <% if (typeof itens !== 'undefined' && itens.length > 0) { %>
                <% itens.forEach(gasto => { %>
                    <tr>
                        <td><%= gasto.description %></td>
                        <td>R$ <%= Number(gasto.amount).toFixed(2) %></td>
                        <td><%= new Date(gasto.purchase_date).toLocaleDateString('pt-BR', {timeZone: 'UTC'}) %></td>                        <td><%= gasto.card_name %></td>
                        <td><%= gasto.folder_name %></td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="5" style="text-align: center; color: #888;">
                        Nenhum registro encontrado.
                    </td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<div class="total">
    Total de contas: <%= (typeof itens !== 'undefined') ? itens.length : 0 %>
</div>

<div class="modal-overlay" id="universalModal" style="display: none;">
    <div class="modal">
        <h2 id="modalTitle">Título Dinâmico</h2>
        <p id="modalInstruction">Instrução Dinâmica</p>
        
        <div id="groupFolder" style="display: none;">
            <input id="nameFolder" placeholder="Nome da Pasta">
        </div>
        
        <div id="groupExFolder" style="display: none;">
            <input id="exFolderName" placeholder="Pasta que deseja excluir">
            <p> Confirme a pasta escrevendo novamente seu nome </p>
            <input id="exFolderConfirm" placeholder="Confirme a pasta que deseja excluir">
        </div>

        <div id="groupCard" style="display: none;">
            <input id="cardBank" placeholder="Nome do Banco">
            <p> Atribua um nome ao cartão </p>
            <input id="cardName" placeholder="Nome/Apelido do cartão">
            <p>Insira a data de fechamento do cartão</p>
            <input type="number" id="closeDate">

            <p>Insira a data de vencimento do cartão</p>
            <input type="number" id="endDate">
        </div>


        <div class="modal-buttons">
            <button class="cancel" onclick="closeModal()"> Cancelar </button>
            <button id="confirmBtn" class="add"> Confirmar </button>
        </div>
    </div>
</div>

<script src="/js/dashboardScript.js"></script>
</body>
</html>